# SQLite (local dev) or PostgreSQL (production) — set via Vercel dashboard for prod
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="super-secret-key-12345-change-in-production"

# Base URL for NextAuth — http://localhost:3000 for local, your-domain for prod
NEXTAUTH_URL="http://localhost:3000"

# Public-facing app URL (used in sitemaps, emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"

# Stripe price IDs (create products in Stripe dashboard)
STRIPE_JET_PRICE_ID=""
STRIPE_STANDARD_PRICE_ID=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_ELITE_PRICE_ID=""

# Stripe webhook secret (get from Stripe dashboard webhook settings)
STRIPE_WEBHOOK_SECRET=""

# External predictor API key
PREDICTOR_API_KEY="placeholder"

# Telegram bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="orananaliz_bot"
